# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carrent_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=           # مطلوب في production

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=30d         # مدة صلاحية الـ token (7d, 30d, ...)

# Payment (Paymob)
PAYMOB_API_KEY=your_key
PAYMOB_INTEGRATION_ID=your_integration_id
PAYMOB_IFRAME_ID=your_iframe_id

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_email
FIREBASE_PRIVATE_KEY=your_private_key

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Storage Configuration
# Set to 'r2' for Cloudflare R2 storage, or 'local' to use local disk storage.
STORAGE_PROVIDER=local

# Cloudflare R2 configuration (Only required if STORAGE_PROVIDER=r2)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://93d746b2e64c8d84815d7aaacac39578.r2.cloudflarestorage.com
R2_BUCKET_NAME=eazycar
R2_PUBLIC_URL=https://your-public-url.com

# Test Account (للـ testing فقط — لا تشيله في production)
TEST_PHONE=+201222222222
TEST_OTP=111111
